# ─── Polymarket / Polygon credentials ────────────────────────────────
POLYGON_PRIVATE_KEY="YOUR_WALLET_PRIVATE_KEY"   # L1 signing key
POLY_API_KEY=""           # L2 API key (auto-derived if blank)
POLY_API_SECRET=""
POLY_API_PASSPHRASE=""
POLY_CHAIN_ID=137         # 137 = Polygon mainnet, 80002 = Amoy testnet

# ─── Web3 / CTF contract ─────────────────────────────────────────────
POLYGON_RPC_URL="https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY"
CTF_CONTRACT_ADDRESS="0x4D970a446C56654e805562095dB1E0BcB1b623E0"
NEG_RISK_ADAPTER_ADDRESS="0xd91E80cF2E7be2e162c6513ceD06f1dD0dA35296"  # NegRisk adapter (do not change)

# ─── Falcon / Heisenberg analytics ───────────────────────────────────
FALCON_API_KEY="YOUR_FALCON_API_KEY"

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL="sqlite:///polybot.db"

# ─── Execution mode ───────────────────────────────────────────────────
DRY_RUN=true             # true = never post real orders; false = LIVE money at stake

# ─── Market discovery ─────────────────────────────────────────────────
MARKETS_CONFIG=            # Path to markets.json (leave blank to auto-discover)
MIN_VOLUME_FILTER=50000    # Minimum 24h volume (USD) for auto-discovered markets
BANKROLL_USDC=1000         # Your estimated trading bankroll in USDC

# ─── Risk management ──────────────────────────────────────────────────
MAX_POSITION_SIZE_PCT=0.05      # Max % of bankroll per trade
DAILY_LOSS_LIMIT_PCT=0.05       # Pause trading after losing this % in a day
TOTAL_DRAWDOWN_LIMIT_PCT=0.25   # Auto-shutdown after losing this % of initial bank
KELLY_FRACTION=0.5              # Fraction of Kelly to use (0.5 = half-Kelly)
MAX_SPREAD=0.05                 # Skip execution if spread wider than this
TAKER_FEE_RATE=0.002            # Estimated taker fee rate

# ─── Strategies (enable/disable each independently) ───────────────────
STRATEGY_MOMENTUM=true
STRATEGY_LOGICAL_ARB=true
STRATEGY_AMM=false             # Set to true to enable AMM quoting
STRATEGY_AI_ARB=false          # Requires XAI_API_KEY
STRATEGY_COPY_TRADING=false    # Requires FALCON_API_KEY

# ─── Strategy-specific tuning ────────────────────────────────────────
MOMENTUM_SCALP_SIZE=50
AMM_SPREAD=0.02
AMM_SIZE=100
ARB_THRESHOLD=1.05
ARB_SIZE=80
AI_ARB_TOKEN_ID=               # Token ID to run AI arb on
AI_ARB_MARKET_NAME="Will BTC reach $100k by EOY?"
COPY_TRADE_TARGET_WALLET=
COPY_TRADE_MULTIPLIER=0.1      # Mirror at 10% of target size

# ─── Auto-claim / redemption ──────────────────────────────────────────
ENABLE_AUTO_CLAIM=false
AUTO_CLAIM_INTERVAL_HOURS=6

# ─── UI & Monitoring ──────────────────────────────────────────────────
ENABLE_DASHBOARD=true
ENABLE_OPERATOR_UI=false
OPERATOR_UI_HOST=127.0.0.1
OPERATOR_UI_PORT=8081
OPERATOR_UI_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
XAI_API_KEY=                   # For Grok AI probability edge

# ─── Circuit Breaker ──────────────────────────────────────────────────
CIRCUIT_BREAKER_ENABLED=true
CB_MAX_CONSECUTIVE_ERRORS=4    # Trip after N consecutive API/order errors
CB_DRAWDOWN_PCT_TRIGGER=0.03   # Trip after 3% bankroll loss in rolling window
CB_DRAWDOWN_WINDOW_MINUTES=5   # Rolling window for drawdown check (minutes)
CB_COOL_DOWN_MINUTES=10        # Auto-reset after this many minutes

# ─── Retry / Rate-limit defense ───────────────────────────────────────
CB_MAX_RETRY_ATTEMPTS=5        # Max retries per API call
CB_BASE_RETRY_DELAY=1.0        # Initial retry delay (seconds, doubles each attempt)

# ─── VPS / Deployment ─────────────────────────────────────────────────
VPS_LATENCY_MODE=false         # Set true on VPS to log latency optimisations
HEALTH_CHECK_PORT=8080         # HTTP health endpoint (0 = disabled)
REDEEM_INTERVAL_MINUTES=60     # How often to scan and redeem settled positions
